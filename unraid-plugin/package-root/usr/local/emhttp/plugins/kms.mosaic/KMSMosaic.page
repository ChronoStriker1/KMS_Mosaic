      <div class="kms-service-grid">
        <div class="kms-field">
          <label for="kmsServiceBoot">Start `kms_mosaic` at boot</label>
          <select id="kmsServiceBoot" name="SERVICE">
            <?=mk_option($service, "enable", "Yes");?>
            <?=mk_option($service, "disable", "No");?>
          </select>
        </div>

        <div class="kms-field">
          <label for="kmsWebBoot">Start preview service at boot</label>
          <select id="kmsWebBoot" name="WEB_SERVICE">
            <?=mk_option($web_service, "enable", "Yes");?>
            <?=mk_option($web_service, "disable", "No");?>
          </select>
        </div>

        <div class="kms-field">
          <label for="kmsWebPort">Preview service port</label>
          <input id="kmsWebPort" name="WEB_PORT" type="text" value="<?=htmlspecialchars($web_port);?>">
        </div>

        <div class="kms-field">
          <label for="kmsConfigPath">Config path</label>
          <input id="kmsConfigPath" name="CONFIG_PATH" type="text" value="<?=htmlspecialchars($config_path);?>">
        </div>

        <div class="kms-actions service-actions" style="grid-column: 1 / -1;">
          <button type="button" onclick="kmsSavePluginSettings()">Apply</button>
          <button type="button" onclick="kmsControl('start')">Start</button>
          <button type="button" onclick="kmsControl('restart')">Restart</button>
          <button type="button" onclick="kmsControl('stop')">Stop</button>
