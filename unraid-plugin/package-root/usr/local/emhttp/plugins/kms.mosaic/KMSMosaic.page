<script>
const kmsActionUrl = '/plugins/kms.mosaic/include/actions.php';
const kmsInitialStatus = <?php echo $initial_status_json ?: '{}'; ?>;
const kmsCsrfToken = typeof window.csrf_token === 'string' ? window.csrf_token : '';
let kmsEmbeddedLoaded = false;
let kmsEmbeddedStylesInstalled = false;
let kmsEmbeddedLoadPromise = null;

function kmsEmbeddedUrl(action) {
  return `${kmsActionUrl}?action=${encodeURIComponent(action)}`;
}

function kmsRewriteBackendHtml(html) {
  return html
    .replaceAll('/api/state', `${kmsActionUrl}?action=backend_state`)
    .replaceAll('/api/config', `${kmsActionUrl}?action=backend_config`)
    .replaceAll('/api/raw_config', `${kmsActionUrl}?action=backend_raw_config`)
      .replaceAll('/api/webrtc-offer', `${kmsActionUrl}?action=backend_webrtc_offer`)
      .replaceAll('/api/media?path=', `${kmsActionUrl}?action=backend_media&path=`);
}

function kmsInstallFetchShim() {
  if (window.__kmsFetchShimInstalled) return;
  const originalFetch = window.fetch.bind(window);
  window.fetch = async (input, init = undefined) => {
    const rawUrl = typeof input === 'string' ? input : (input?.url || '');
    if (!rawUrl.includes('/plugins/kms.mosaic/include/actions.php')) {
      return originalFetch(input, init);
    }
    const url = new URL(rawUrl, window.location.origin);
    const method = (init?.method || (typeof input !== 'string' ? input.method : '') || 'GET').toUpperCase();
    if (method === 'POST') {
      const form = new URLSearchParams();
      if (kmsCsrfToken) form.set('csrf_token', kmsCsrfToken);
      const contentType = (init?.headers && (init.headers['Content-Type'] || init.headers['content-type'])) || '';
      if (contentType.includes('application/json') && typeof init?.body === 'string') {
        form.set('payload', init.body);
      } else if (typeof init?.body === 'string') {
        const source = new URLSearchParams(init.body);
        source.forEach((value, key) => form.append(key, value));
      }
      return originalFetch(url.toString(), {
        method: 'POST',
        credentials: init?.credentials || 'same-origin',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: form.toString(),
      });
    }
    if (kmsCsrfToken && !url.searchParams.has('csrf_token')) {
      url.searchParams.set('csrf_token', kmsCsrfToken);
    }
    const nextInput = typeof input === 'string'
      ? url.toString()
      : new Request(url.toString(), input);
    return originalFetch(nextInput, init);
  };
  window.__kmsFetchShimInstalled = true;
}

