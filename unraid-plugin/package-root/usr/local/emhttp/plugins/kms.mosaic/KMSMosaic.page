<?php
$plugin = 'kms.mosaic';
$cfg = parse_plugin_cfg($plugin);
$service = $cfg['SERVICE'] ?? 'enable';
$web_service = $cfg['WEB_SERVICE'] ?? 'enable';
$web_port = $cfg['WEB_PORT'] ?? '8788';
$config_path = $cfg['CONFIG_PATH'] ?? '/boot/config/kms_mosaic.conf';
$service_script = "/usr/local/emhttp/plugins/{$plugin}/scripts/kms_mosaic-service";
$web_wrapper = "/usr/local/bin/kms_mosaic_web";
$initial_status = [
  'service' => $service,
  'web_service' => $web_service,
  'web_port' => $web_port,
  'config_path' => $config_path,
  'kms_running' => false,
  'web_running' => false,
  'kms_pid' => '',
  'web_pid' => '',
];
$service_status_raw = @shell_exec(escapeshellcmd($service_script) . ' ' . escapeshellarg('status'));
if (is_string($service_status_raw) && trim($service_status_raw) !== '') {
  $decoded = json_decode($service_status_raw, true);
  if (is_array($decoded)) {
    $initial_status = array_merge($initial_status, $decoded);
  }
}
$initial_status_json = json_encode($initial_status, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
$embedded_html = '';
$embedded_payload_json = 'null';
$embedded_cmd = escapeshellcmd($web_wrapper) . ' --config ' . escapeshellarg($config_path) . ' --print-html 2>/dev/null';
$embedded_html_raw = @shell_exec($embedded_cmd);
if (is_string($embedded_html_raw) && trim($embedded_html_raw) !== '') {
  $embedded_html = $embedded_html_raw;
}
$embedded_payload_cmd = escapeshellcmd($web_wrapper) . ' --config ' . escapeshellarg($config_path) . ' --dump-state 2>/dev/null';
$embedded_payload_raw = @shell_exec($embedded_payload_cmd);
if (is_string($embedded_payload_raw) && trim($embedded_payload_raw) !== '') {
  $decoded_payload = json_decode($embedded_payload_raw, true);
  if (is_array($decoded_payload)) {
    $embedded_payload_json = json_encode($decoded_payload, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
  }
}
?>
