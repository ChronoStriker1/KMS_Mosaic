function kmsScopeCss(css) {
  return css.replace(/(^|})(\s*[^@{}][^{}]*)\{/g, (match, prefix, selectorGroup) => {
    const rewritten = selectorGroup
      .split(',')
      .map((selector) => {
        const trimmed = selector.trim();
        if (!trimmed) return '';
        if (trimmed.startsWith('#kmsUiMount')) return trimmed;
        return `#kmsUiMount ${trimmed}`;
      })
      .filter(Boolean)
      .join(', ');
    return `${prefix}${rewritten}{`;
  });
}

function kmsInstallEmbeddedStyles(doc) {
  if (kmsEmbeddedStylesInstalled) return;
  const styleNode = document.createElement('style');
  styleNode.id = 'kmsEmbeddedStyles';
  const embeddedCss = Array.from(doc.querySelectorAll('style')).map((style) => style.textContent).join('\n');
  styleNode.textContent = kmsScopeCss(embeddedCss) + '\n' + kmsEmbeddedOverrides();
  document.head.appendChild(styleNode);
  kmsEmbeddedStylesInstalled = true;
}

function kmsUpdateStatus(data) {
  const el = document.getElementById('kmsStatus');
  const meta = document.getElementById('kmsMeta');
  const kmsOk = !!data.kms_running;
  const webOk = !!data.web_running;
  el.className = `kms-status ${kmsOk ? 'ok' : 'bad'}`;
  el.textContent = `kms_mosaic: ${kmsOk ? 'running' : 'stopped'} | preview service: ${webOk ? 'running' : 'stopped'}`;
  meta.textContent = `${data.kms_pid ? 'kms pid: ' + data.kms_pid : 'kms pid: —'}${data.web_pid ? ' | preview pid: ' + data.web_pid : ' | preview pid: —'}`;
}

async function kmsPost(action, extra = {}, jsonBody = false) {
  let response;
  if (jsonBody) {
    const url = new URL(kmsActionUrl, window.location.origin);
    url.searchParams.set('action', action);
    if (kmsCsrfToken) url.searchParams.set('csrf_token', kmsCsrfToken);
    response = await fetch(url.toString(), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(extra)
    });
  } else {
    const qs = new URLSearchParams({ action, ...extra });
    if (kmsCsrfToken) qs.set('csrf_token', kmsCsrfToken);
    response = await fetch(`${kmsActionUrl}?${qs}`, { method: 'GET' });
  }
  const contentType = response.headers.get('content-type') || '';
  const data = contentType.includes('application/json') ? await response.json() : await response.text();
  if (!response.ok) {
    const message = typeof data === 'string' ? data : (data.error || 'Request failed');
    throw new Error(message);
  }
  return data;
}

async function kmsRefreshStatus() {
  try {
    const data = await kmsPost('status');
    kmsUpdateStatus(data);
    try {
      await kmsEnsureEmbeddedLoaded();
    } catch (err) {
      console.error('KMS Mosaic editor load failed during status refresh', err);
    }
  } catch (err) {
    document.getElementById('kmsStatus').className = 'kms-status bad';
    document.getElementById('kmsStatus').textContent = err.message || 'Status failed';
  }
}

async function kmsSavePluginSettings() {
  try {
    const data = await kmsPost('save', {
      SERVICE: document.getElementById('kmsServiceBoot').value,
      WEB_SERVICE: document.getElementById('kmsWebBoot').value,
      WEB_PORT: document.getElementById('kmsWebPort').value,
      CONFIG_PATH: document.getElementById('kmsConfigPath').value
    });
    kmsUpdateStatus(data);
    try {
      await kmsEnsureEmbeddedLoaded();
    } catch (err) {
      console.error('KMS Mosaic editor load failed after applying plugin settings', err);
    }
  } catch (err) {
    document.getElementById('kmsStatus').className = 'kms-status bad';
    document.getElementById('kmsStatus').textContent = err.message || 'Apply failed';
  }
}

async function kmsControl(action) {
  try {
    const data = await kmsPost(action);
    kmsUpdateStatus(data);
    try {
      await kmsEnsureEmbeddedLoaded();
    } catch (err) {
      console.error(`KMS Mosaic editor load failed after ${action}`, err);
    }
  } catch (err) {
    document.getElementById('kmsStatus').className = 'kms-status bad';
    document.getElementById('kmsStatus').textContent = err.message || `${action} failed`;
  }
}

async function kmsSaveConfigState() {
  try {
    await kmsEnsureEmbeddedLoaded();
    if (typeof window.saveState !== 'function') {
      throw new Error('Embedded config save is unavailable');
    }
    await window.saveState();
    setTimeout(() => { kmsRefreshStatus().catch(() => {}); }, 1500);
  } catch (err) {
    document.getElementById('kmsStatus').className = 'kms-status bad';
    document.getElementById('kmsStatus').textContent = err.message || 'Save Config failed';
  }
}

async function kmsReloadConfigState() {
  try {
    await kmsEnsureEmbeddedLoaded();
    if (typeof window.loadState !== 'function') {
      throw new Error('Embedded config reload is unavailable');
    }
    await window.loadState();
    setTimeout(() => { kmsRefreshStatus().catch(() => {}); }, 250);
  } catch (err) {
    document.getElementById('kmsStatus').className = 'kms-status bad';
    document.getElementById('kmsStatus').textContent = err.message || 'Reload From Disk failed';
  }
}

function kmsSyncVisibilityMode() {
  const group = document.getElementById('kmsVisibilityMode');
  if (!group || typeof window.currentVisibilityMode !== 'function') return;
  try {
    const mode = window.currentVisibilityMode();
    group.querySelectorAll('button[data-mode]').forEach((button) => {
      button.classList.toggle('kms-active', button.dataset.mode === mode);
    });
  } catch (err) {
    console.error('Unable to sync KMS Mosaic visibility mode', err);
  }
}

async function kmsSetVisibilityMode(mode) {
  try {
    await kmsEnsureEmbeddedLoaded();
    if (typeof window.setVisibilityMode !== 'function') {
      throw new Error('Embedded visibility mode control is unavailable');
    }
    await window.setVisibilityMode(mode);
    kmsSyncVisibilityMode();
    setTimeout(() => { kmsRefreshStatus().catch(() => {}); }, 1200);
  } catch (err) {
    document.getElementById('kmsStatus').className = 'kms-status bad';
    document.getElementById('kmsStatus').textContent = err.message || 'Visibility update failed';
  }
}

async function kmsEnsureEmbeddedLoaded() {
  if (kmsEmbeddedLoaded) return;
  if (kmsEmbeddedLoadPromise) return kmsEmbeddedLoadPromise;
  const mount = document.getElementById('kmsUiMount');
  kmsEmbeddedLoadPromise = (async () => {
    try {
      const [htmlResponse, stateResponse] = await Promise.all([
        fetch(kmsEmbeddedUrl('backend_html')),
        fetch(kmsEmbeddedUrl('backend_state'))
      ]);
      const html = await htmlResponse.text();
      if (!htmlResponse.ok) throw new Error(html || 'Unable to load editor');
      const statePayload = await stateResponse.json();
      if (!stateResponse.ok) throw new Error(statePayload.error || 'Unable to load editor state');
      const rewritten = kmsRewriteBackendHtml(html)
        .replace(
          'document.getElementById("configPath").textContent = `Config: ${configPath}`;',
          'const configPathNode = document.getElementById("configPath"); if (configPathNode) configPathNode.textContent = `Config: ${configPath}`;'
        )
        .replace(
          'loadState().catch(err => setStatus(err.message, true));',
          'window.__kmsEmbeddedInitialLoadDeferred = true;'
        );
      const doc = new DOMParser().parseFromString(rewritten, 'text/html');
      kmsInstallEmbeddedStyles(doc);
      const scripts = Array.from(doc.querySelectorAll('script')).map((script) => script.textContent || '');
      doc.querySelectorAll('script').forEach((script) => script.remove());
      mount.className = '';
      mount.innerHTML = doc.body.innerHTML;
      window.__kmsEmbeddedInitialPayload = statePayload;
      kmsInstallFetchShim();
      scripts.forEach((text) => {
        const script = document.createElement('script');
        script.textContent = text;
        mount.appendChild(script);
      });
      if (typeof window.fillForm === 'function') {
        window.fillForm(statePayload.state, statePayload.config_path, statePayload.raw_config);
      }
      kmsSyncVisibilityMode();
      if (typeof window.scheduleLivePreview === 'function') {
        window.scheduleLivePreview();
      }
      if (typeof window.setStatus === 'function') {
        window.setStatus(`Loaded ${statePayload.config_path}`, false, true);
      }
      kmsEmbeddedLoaded = true;
    } catch (err) {
      mount.className = 'kms-ui-error';
      mount.textContent = err.message || 'Unable to load editor.';
      throw err;
    } finally {
      kmsEmbeddedLoadPromise = null;
    }
  })();
  return kmsEmbeddedLoadPromise;
}

$(function() {
  document.getElementById('kmsSaveConfigBtn').addEventListener('click', kmsSaveConfigState);
  document.getElementById('kmsReloadConfigBtn').addEventListener('click', kmsReloadConfigState);
  document.querySelectorAll('#kmsVisibilityMode button[data-mode]').forEach((button) => {
    button.addEventListener('click', () => kmsSetVisibilityMode(button.dataset.mode));
  });
  kmsEnsureEmbeddedLoaded();
  kmsRefreshStatus();
});
</script>
