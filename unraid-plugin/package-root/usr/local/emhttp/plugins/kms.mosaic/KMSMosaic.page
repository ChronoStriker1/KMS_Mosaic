<?php
$plugin = 'kms.mosaic';
$cfg = parse_plugin_cfg($plugin);
$service = $cfg['SERVICE'] ?? 'enable';
$web_service = $cfg['WEB_SERVICE'] ?? 'enable';
$web_port = $cfg['WEB_PORT'] ?? '8788';
$config_path = $cfg['CONFIG_PATH'] ?? '/boot/config/kms_mosaic.conf';
$service_script = "/usr/local/emhttp/plugins/{$plugin}/scripts/kms_mosaic-service";
$initial_status = [
  'service' => $service,
  'web_service' => $web_service,
  'web_port' => $web_port,
  'config_path' => $config_path,
  'kms_running' => false,
  'web_running' => false,
  'kms_pid' => '',
  'web_pid' => '',
];
$service_status_raw = @shell_exec(escapeshellcmd($service_script) . ' ' . escapeshellarg('status'));
if (is_string($service_status_raw) && trim($service_status_raw) !== '') {
  $decoded = json_decode($service_status_raw, true);
  if (is_array($decoded)) {
    $initial_status = array_merge($initial_status, $decoded);
  }
}
$initial_status_json = json_encode($initial_status, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
?>
