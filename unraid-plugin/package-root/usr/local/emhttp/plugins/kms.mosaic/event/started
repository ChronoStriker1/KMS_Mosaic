#!/bin/bash
set -euo pipefail

CFG=/boot/config/plugins/kms.mosaic/kms.mosaic.cfg
[ -r "$CFG" ] && source "$CFG"

if [ "${SERVICE:-enable}" = "enable" ] || [ "${WEB_SERVICE:-enable}" = "enable" ]; then
  /usr/local/emhttp/plugins/kms.mosaic/scripts/kms_mosaic-service start >/dev/null 2>&1 || true
fi
